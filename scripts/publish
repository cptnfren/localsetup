#!/usr/bin/env bash
# Purpose: Publish workflow for consolidated localsetup v2 repo.
#          Run after committing changes. This script:
#          1) Validates context and rules
#          2) Runs automated tests
#          3) Refreshes skill index and validates skill registration
#          4) Regenerates doc artifacts
#          5) Bumps VERSION (from commit message or explicit flag)
#          6) Commits bump and doc sync
#          7) Optionally pushes to origin/main
# Usage:   ./scripts/publish [--major|--minor|--patch] [--push]
#          With no bump flag, infers bump type from the last commit message.
# Created: 2026-04-01 (consolidated from publish and publish-from-dogfood)
# Last updated: 2026-04-01

set -euo pipefail

REPO_ROOT=""
if command -v git >/dev/null 2>&1; then
  REPO_ROOT="$(git rev-parse --show-toplevel 2>/dev/null)" || true
fi
[[ -z "$REPO_ROOT" ]] || [[ ! -d "$REPO_ROOT" ]] && REPO_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$REPO_ROOT"

BUMP_FLAG=""
DO_PUSH=false
while [[ $# -gt 0 ]]; do
  case "$1" in
    --major|--minor|--patch) BUMP_FLAG="$1"; shift ;;
    --push) DO_PUSH=true; shift ;;
    -h|--help)
      sed -n '2,12p' "$0" | sed 's/^# \?//'
      exit 0
      ;;
    *) shift ;;
  esac
done

BUMP_SCRIPT="$REPO_ROOT/scripts/bump-version"
[[ -f "$BUMP_SCRIPT" ]] || { echo "Missing $BUMP_SCRIPT" >&2; exit 1; }
[[ -x "$BUMP_SCRIPT" ]] || chmod +x "$BUMP_SCRIPT" 2>/dev/null || true

# =============================================================================
# Step 1: Validate context and rules
# =============================================================================
echo "== Validate context and rules =="
if [[ -x "_localsetup/tools/verify_context" ]]; then
  "_localsetup/tools/verify_context" || { echo "verify_context failed" >&2; exit 1; }
elif [[ -x "_localsetup/tools/verify_context.py" ]]; then
  python3 "_localsetup/tools/verify_context.py" || { echo "verify_context failed" >&2; exit 1; }
fi

if [[ -x "_localsetup/tools/verify_rules" ]]; then
  "_localsetup/tools/verify_rules" || { echo "verify_rules failed" >&2; exit 1; }
elif [[ -x "_localsetup/tools/verify_rules.py" ]]; then
  python3 "_localsetup/tools/verify_rules.py" || { echo "verify_rules failed" >&2; exit 1; }
fi
echo "  context and rules: OK"

# =============================================================================
# Step 2: Run automated tests
# =============================================================================
echo "== Run automated tests =="
if [[ -x "_localsetup/tests/automated_test.sh" ]]; then
  "_localsetup/tests/automated_test.sh" || { echo "automated_test.sh failed" >&2; exit 1; }
  echo "  automated tests: OK"
elif [[ -x "_localsetup/tests/automated_test.py" ]]; then
  python3 "_localsetup/tests/automated_test.py" || { echo "automated_test.py failed" >&2; exit 1; }
  echo "  automated tests: OK"
fi

# =============================================================================
# Step 3: Refresh public skill index
# =============================================================================
echo "== Refresh public skill index =="
if [[ -x "_localsetup/tools/refresh_public_skill_index.py" ]]; then
  python3 "_localsetup/tools/refresh_public_skill_index.py"
  echo "  skill index: refreshed"
elif [[ -f "_localsetup/tools/refresh_public_skill_index.py" ]]; then
  python3 "_localsetup/tools/refresh_public_skill_index.py"
  echo "  skill index: refreshed"
fi

# =============================================================================
# Step 4: Validate skill registration coverage
# =============================================================================
echo "== Validate skill registration coverage =="
REGISTRY_FILE="_localsetup/docs/PLATFORM_REGISTRY.md"
if [[ -f "$REGISTRY_FILE" ]] && command -v rg >/dev/null 2>&1; then
  missing_count=0
  SKILL_COVERAGE_SKIP_REGEX='^localsetup-context$'
  shopt -s nullglob
  for skill_dir in _localsetup/skills/localsetup-*; do
    [[ -d "$skill_dir" ]] || continue
    skill_id="$(basename "$skill_dir")"
    if [[ "$skill_id" =~ $SKILL_COVERAGE_SKIP_REGEX ]]; then
      continue
    fi
    if ! rg -n --fixed-strings "$skill_id" "$REGISTRY_FILE" >/dev/null 2>&1; then
      echo "  missing registration: $skill_id"
      missing_count=$((missing_count + 1))
    fi
  done
  shopt -u nullglob
  if [[ "$missing_count" -gt 0 ]]; then
    echo "Registration coverage check failed ($missing_count missing)" >&2
    exit 1
  fi
  echo "  registration coverage: OK"
fi

# =============================================================================
# Step 5: Regenerate doc artifacts
# =============================================================================
echo "== Regenerate doc artifacts =="
if [[ -f "$REPO_ROOT/scripts/generate-doc-artifacts" ]]; then
  [[ -x "$REPO_ROOT/scripts/generate-doc-artifacts" ]] || chmod +x "$REPO_ROOT/scripts/generate-doc-artifacts" 2>/dev/null || true
  "$REPO_ROOT/scripts/generate-doc-artifacts"
fi

# =============================================================================
# Step 6: Bump version
# =============================================================================
echo "== Bump version =="
if [[ -n "$BUMP_FLAG" ]]; then
  NEW_VERSION="$("$BUMP_SCRIPT" "$BUMP_FLAG")"
else
  MSG_FILE="${TMPDIR:-/tmp}/localsetup_last_commit_msg.$$"
  git log -1 --format=%B > "$MSG_FILE" 2>/dev/null || true
  if [[ ! -s "$MSG_FILE" ]]; then
    NEW_VERSION="$("$BUMP_SCRIPT" --patch)"
  else
    NEW_VERSION="$("$BUMP_SCRIPT" "$MSG_FILE")"
  fi
  rm -f "$MSG_FILE"
fi
echo "  version: $NEW_VERSION"

# =============================================================================
# Step 7: Stage version and doc outputs
# =============================================================================
git add VERSION

add_if_exists() {
  local path="$1"
  if [[ -e "$path" ]]; then
    git add "$path"
  fi
}

add_glob_if_any() {
  local pattern="$1"
  shopt -s nullglob
  local matches=( $pattern )
  shopt -u nullglob
  if [[ ${#matches[@]} -gt 0 ]]; then
    git add "${matches[@]}"
  fi
}

add_if_exists README.md
add_if_exists _localsetup/README.md
add_glob_if_any "_localsetup/docs/*.md"
add_glob_if_any "docs/*.md"
add_if_exists _localsetup/docs/_generated/facts.json

# =============================================================================
# Step 8: Commit
# =============================================================================
if git diff --staged --quiet; then
  echo "Nothing to commit (version $NEW_VERSION already in sync)."
  exit 0
fi

git commit -m "chore: bump to $NEW_VERSION and sync docs"

# =============================================================================
# Step 9: Optional push
# =============================================================================
if [[ "$DO_PUSH" == true ]]; then
  git push origin main
  echo "Published: $NEW_VERSION (pushed to origin main)"
else
  echo "Published: $NEW_VERSION (committed; run 'git push origin main' to push)"
fi
