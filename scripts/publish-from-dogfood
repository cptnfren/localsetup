#!/usr/bin/env bash
# Purpose: Harvest dogfood runtime changes from public repo, sync package source,
#          validate cross-platform registration coverage, bump version, commit, and optionally push.
#          Harvest uses "newer wins" (sync-cursor-to-source.py): only overwrites when source is newer.
# Created Date: 2026-02-20
# Last Updated Date: 2026-02-24

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAINTAINER_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
BUMP_SCRIPT="$MAINTAINER_ROOT/scripts/bump-version"

PUBLIC_REPO=""
DO_PUSH=false
DO_COMMIT=true
BUMP_FLAG=""

usage() {
  cat <<'EOF'
publish-from-dogfood

Usage:
  ./scripts/publish-from-dogfood --public-repo /path/to/localsetup-2 [--major|--minor|--patch] [--push] [--no-commit]

What it does:
  1) Harvests Cursor runtime edits back to package source (newer wins: only overwrites when .cursor is newer):
     - .cursor/skills/localsetup-* -> _localsetup/skills (file-by-file)
     - .cursor/rules/localsetup-context*.mdc/md -> _localsetup/templates/cursor/
  2) Refreshes generated artifacts and validation dependencies.
  3) Validates platform registration coverage for every skill.
  4) Bumps VERSION from commit message (or explicit bump flag), regenerates docs.
  5) Commits changes, and optionally pushes to origin/main.

Options:
  --public-repo PATH   Required. Path to localsetup-2 repo.
  --major|--minor|--patch
                       Force version bump type. Default infers from last commit.
  --push               Push to origin/main after commit.
  --no-commit          Stop after sync/validation (no version bump, commit, or push).
  -h, --help           Show this help.
EOF
}

die() {
  echo "Error: $*" >&2
  exit 1
}

abs_path() {
  python3 - "$1" <<'PY'
import os,sys
print(os.path.abspath(sys.argv[1]))
PY
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --public-repo) PUBLIC_REPO="${2:-}"; shift 2 ;;
    --major|--minor|--patch) BUMP_FLAG="$1"; shift ;;
    --push) DO_PUSH=true; shift ;;
    --no-commit) DO_COMMIT=false; shift ;;
    -h|--help) usage; exit 0 ;;
    *) die "Unknown option: $1" ;;
  esac
done

[[ -n "$PUBLIC_REPO" ]] || die "--public-repo is required"
PUBLIC_REPO="$(abs_path "$PUBLIC_REPO")"
[[ -d "$PUBLIC_REPO" ]] || die "Public repo path does not exist: $PUBLIC_REPO"
[[ -x "$BUMP_SCRIPT" ]] || die "Missing executable bump script: $BUMP_SCRIPT"

pushd "$PUBLIC_REPO" >/dev/null

git rev-parse --is-inside-work-tree >/dev/null 2>&1 || die "Not a git repo: $PUBLIC_REPO"
[[ -d "_localsetup/skills" ]] || die "Missing _localsetup/skills in public repo"
[[ -d "_localsetup/templates/cursor" ]] || die "Missing _localsetup/templates/cursor in public repo"
[[ -x "_localsetup/tools/deploy" ]] || die "Missing deploy script: _localsetup/tools/deploy"

# Harvest .cursor -> _localsetup with "newer wins": only overwrite when source is newer (or dest missing).
SYNC_SCRIPT="$MAINTAINER_ROOT/scripts/sync-cursor-to-source.py"
[[ -x "$SYNC_SCRIPT" ]] || [[ -f "$SYNC_SCRIPT" ]] || die "Missing sync script: $SYNC_SCRIPT"
python3 "$SYNC_SCRIPT" --public-repo "$PUBLIC_REPO" || die "sync-cursor-to-source failed"

echo "== Refresh generated artifacts =="
python3 "_localsetup/tools/refresh_public_skill_index.py"
python3 "_localsetup/tools/skill_validation_scan.py" --ensure-only --scan-root "$PUBLIC_REPO"
python3 "_localsetup/tools/generate_docs_artifacts.py" --repo-root "$PUBLIC_REPO"

echo "== Re-deploy Cursor runtime from source =="
"_localsetup/tools/deploy" --tools "cursor" --root "$PUBLIC_REPO"

echo "== Validate runtime and framework =="
"_localsetup/tools/verify_context"
"_localsetup/tools/verify_rules"
"_localsetup/tests/automated_test.sh"

echo "== Validate cross-platform registration coverage =="
REGISTRY_FILE="_localsetup/docs/PLATFORM_REGISTRY.md"
[[ -f "$REGISTRY_FILE" ]] || die "Missing platform registry: $REGISTRY_FILE"
mapfile -t REG_FILES < <(awk -F'|' '
  /^\|[[:space:]]*[^|]+[[:space:]]*\|[[:space:]]*_localsetup\// {
    gsub(/^[[:space:]]+|[[:space:]]+$/, "", $3);
    print $3
  }' "$REGISTRY_FILE" | sort -u)

missing_count=0
SKILL_COVERAGE_SKIP_REGEX='^localsetup-context$'
shopt -s nullglob
for skill_dir in _localsetup/skills/localsetup-*; do
  [[ -d "$skill_dir" ]] || continue
  skill_id="$(basename "$skill_dir")"
  if [[ "$skill_id" =~ $SKILL_COVERAGE_SKIP_REGEX ]]; then
    continue
  fi
  for reg_file in "${REG_FILES[@]}"; do
    [[ -f "$reg_file" ]] || continue
    if ! rg -n --fixed-strings "$skill_id" "$reg_file" >/dev/null 2>&1; then
      echo "  missing registration: $skill_id -> $reg_file"
      missing_count=$((missing_count + 1))
    fi
  done
done
shopt -u nullglob

if [[ "$missing_count" -gt 0 ]]; then
  die "Registration coverage check failed ($missing_count missing references). Update listed files, then rerun."
fi
echo "  registration coverage: OK"

if [[ "$DO_COMMIT" == false ]]; then
  echo "No-commit mode enabled. Sync and validation complete."
  popd >/dev/null
  exit 0
fi

echo "== Bump version and regenerate docs =="
if [[ -n "$BUMP_FLAG" ]]; then
  "$BUMP_SCRIPT" "$BUMP_FLAG" >/dev/null
else
  MSG_FILE="${TMPDIR:-/tmp}/localsetup_last_commit_msg.$$"
  git log -1 --format=%B > "$MSG_FILE" 2>/dev/null || true
  "$BUMP_SCRIPT" "$MSG_FILE" >/dev/null
  rm -f "$MSG_FILE"
fi
NEW_VERSION="$(tr -d '\r\n' < VERSION)"
python3 "_localsetup/tools/generate_docs_artifacts.py" --repo-root "$PUBLIC_REPO"

echo "== Stage and guard against runtime-only artifacts =="
git add -A
forbidden='^(\.cursor/skills/|\.claude/|\.agents/|AGENTS\.md$|skills/|_localsetup/\.localsetup-meta/)'
if git diff --cached --name-only | rg -n "$forbidden" >/dev/null 2>&1; then
  echo "Forbidden runtime artifacts staged:" >&2
  git diff --cached --name-only | rg "$forbidden" >&2 || true
  die "Unstage/remove runtime artifacts and rerun."
fi

if git diff --cached --quiet; then
  echo "No changes to commit."
  popd >/dev/null
  exit 0
fi

git commit -m "chore: bump to $NEW_VERSION and sync dogfood packaging"

if [[ "$DO_PUSH" == true ]]; then
  git push origin main
  echo "Published to origin/main, version $NEW_VERSION"
else
  echo "Committed version $NEW_VERSION. Run 'git push origin main' when ready."
fi

popd >/dev/null
