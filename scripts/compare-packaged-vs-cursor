#!/usr/bin/env bash
# Purpose: Wrapper for compare-packaged-vs-cursor.py. Compare packaged source with .cursor in public repo.
# Created: 2026-02-20
# Last updated: 2026-02-20

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
MAINTAINER_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
PY_SCRIPT="$MAINTAINER_ROOT/scripts/compare-packaged-vs-cursor.py"

if [[ ! -f "$PY_SCRIPT" ]]; then
  echo "Error: missing $PY_SCRIPT" >&2
  exit 1
fi

exec python3 "$PY_SCRIPT" "$@"
