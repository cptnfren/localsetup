#!/usr/bin/env bash
# Purpose: Run tmux_ops.py locally or on REMOTE_TMUX_HOST (SSH). Use for VMs/remote/Docker.
# Created: 2026-02-25
# Last updated: 2026-02-25

set -e
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
TOOL="${SCRIPT_DIR}/tmux_ops.py"
REMOTE_HOST="${REMOTE_TMUX_HOST:-}"
REMOTE_CWD="${REMOTE_TMUX_CWD:-/opt/devzone/devops}"

if [[ -z "$REMOTE_HOST" ]]; then
    if [[ ! -r "$TOOL" ]]; then
        echo "tmux_ops: tool not found or not readable: $TOOL" >&2
        exit 1
    fi
    exec python3 "$TOOL" "$@"
fi

# Pass args safely to remote: quote each for the remote shell
escaped=()
for a in "$@"; do
    escaped+=( "$(printf '%q' "$a")" )
done
if ! ssh "$REMOTE_HOST" "cd $(printf '%q' "$REMOTE_CWD") && python3 _localsetup/tools/tmux_ops.py ${escaped[*]}"; then
    echo "tmux_ops: remote run failed (host=$REMOTE_HOST, cwd=$REMOTE_CWD)" >&2
    exit 1
fi
